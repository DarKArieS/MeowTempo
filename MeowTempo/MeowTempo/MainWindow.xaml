<?xml version="1.0" encoding="utf-8"?>

<Window
    x:Class="MeowTempo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MeowTempo"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="MeowTempo">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="#1D1D1D">
        <Grid.RowDefinitions>
            <RowDefinition Height="88" />
            <RowDefinition Height="6" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="28,18,28,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- <Button Grid.Column="0" Width="48" Height="48" Padding="0" Background="Transparent" BorderBrush="Transparent" Foreground="#D7D7D7"> -->
            <!--     <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE80D;" FontSize="29" /> -->
            <!-- </Button> -->
            <!-- <Button Grid.Column="1" Width="48" Height="48" Margin="16,0,0,0" Padding="0" Background="Transparent" BorderBrush="Transparent" Foreground="#D7D7D7"> -->
            <!--     <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE767;" FontSize="28" /> -->
            <!-- </Button> -->

            <TextBlock Grid.Column="0"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="38"
                       FontWeight="Light"
                       Foreground="#D7D7D7"
                       Text="TEMPO" />

            <!-- <Button Grid.Column="3" Width="48" Height="48" Padding="0" Background="Transparent" BorderBrush="Transparent" Foreground="#D7D7D7"> -->
            <!--     <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE9D9;" FontSize="28" /> -->
            <!-- </Button> -->
            <Button Grid.Column="1" Width="48" Height="48" Margin="16,0,0,0" Padding="0" Background="Transparent"
                    BorderBrush="Transparent" Foreground="#D7D7D7">
                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE946;" FontSize="30" />
            </Button>
        </Grid>

        <Border Grid.Row="1" Background="#97FF20" />

        <Grid Grid.Row="2" Padding="40,0,40,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>


                <Border Grid.Column="0" Width="60" Height="60" Background="#97FF20" CornerRadius="38">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="32" FontWeight="Light"
                               Foreground="#4D7C16" Text="⌃" />
                </Border>

                <Border Grid.Column="1"
                        Width="60"
                        Height="60"
                        Background="#97FF20"
                        CornerRadius="38">
                    <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="32"
                               Foreground="#4D7C16" Text="&gt;" />
                </Border>

                <Ellipse Grid.Column="2" Width="60" Height="60" Fill="#97FF20" />

                <Ellipse Grid.Column="3" Width="60" Height="60" Stroke="#97FF20" StrokeThickness="3" />
            </Grid>

            <Grid Grid.Row="1" x:Name="ControlCardHost">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#353535" BorderBrush="#757575" BorderThickness="2" CornerRadius="20">
                    <Grid Padding="32,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*" />
                            <RowDefinition Height="2" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>

                            <Button Name="BpmDecreaseButton" Grid.Column="0" Padding="0" Background="Transparent" BorderBrush="Transparent"
                                    Foreground="#D7D7D7" Content="−" FontSize="52" />

                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           FontSize="34" Foreground="#D7D7D7" Text="♩=" />
                                <TextBlock Name="BpmNumber" Grid.Column="1" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="70" FontWeight="Light" Foreground="#D7D7D7" Text="110" />
                                <TextBlock Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Center"
                                           FontSize="16" FontWeight="SemiBold" Foreground="#D7D7D7" Text="BPM" />
                            </Grid>

                            <Button Name="BpmIncreaseButton" Grid.Column="2" HorizontalAlignment="Right" Padding="0" Background="Transparent"
                                    BorderBrush="Transparent" Foreground="#D7D7D7" Content="+" FontSize="52" />
                        </Grid>

                        <Border Grid.Row="1" Background="#777777" />

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0"
                                    Background="Transparent" BorderBrush="Transparent" Foreground="#D7D7D7"
                                    Content="TAP" FontSize="27" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" x:Name="FooterHost">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="35" FontWeight="Light" Foreground="#D7D7D7" Text="4/4" />

                <Border Name="PlayButton"
                        Grid.Column="1"
                        Width="125"
                        Height="125"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#353535"
                        BorderBrush="#757575"
                        BorderThickness="2"
                        CornerRadius="125">
                    <Button Padding="20" Background="Transparent" BorderBrush="Transparent" Foreground="#D7D7D7">
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE768;" FontSize="82" />
                    </Button>
                </Border>

                <Button Grid.Column="2" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Padding="0" Background="Transparent" BorderBrush="Transparent" Foreground="#D7D7D7">
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8D6;" FontSize="40" />
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Window>